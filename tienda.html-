<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Tienda Tech</title>
    <link rel="stylesheet" href="tienda.css">
</head>

<body>

    <!-- HEADER -->
    <header>
        <div class="logo">💻</div>
        <h1>Tienda Tech</h1>

        <nav>
            <a href="#inicio">Inicio</a>
            <a href="#nosotros">Quiénes somos</a>
            <a href="#productos">Productos</a>
            <a href="#footer">Contacto</a>
        </nav>
    </header>

    <!-- INICIO -->
    <section id="inicio" class="inicio">
        <h2>Bienvenido a Tienda Tech</h2>
        <p>Los mejores productos tecnológicos al mejor precio.</p>
    </section>

    <!-- QUIENES SOMOS -->
    <section id="nosotros">
        <h2>Quiénes somos</h2>
        <p>
            No solo seguimos tendencias; las definimos. Somos un equipo apasionado por desafiar lo establecido y transformar ideas complejas en soluciones tangibles.
        </p>
    </section>

    <!-- PRODUCTOS -->
    <section id="productos">
        <h2>Productos y Servicios</h2>

        <div class="grid">

            <!-- PRODUCTO 1 -->
            <div class="producto">
                <img src="img/laptop.jpeg">
                <h3>Laptop</h3>
                <p>$2,500,000</p>

                <div class="especificaciones">
                    <p>16GB RAM</p>
                    <p>Intel i7</p>
                    <p>SSD 512GB</p>
                </div>

                <button class="btn-comprar">Comprar</button>
            </div>

            <!-- PRODUCTO 2 -->
            <div class="producto">
                <img src="img/teclado.jpg">
                <h3>Teclado Mecánico</h3>
                <p>$250,000</p>

                <div class="especificaciones">
                    <p>RGB</p>
                    <p>Switch Blue</p>
                    <p>USB</p>
                </div>

                <button class="btn-comprar">Comprar</button>
            </div>

            <!-- PRODUCTO 3 -->
            <div class="producto">
                <img src="img/mouse2.png">
                <h3>Mouse Gamer</h3>
                <p>$150,000</p>

                <div class="especificaciones">
                    <p>7200 DPI</p>
                    <p>Iluminación LED</p>
                    <p>6 botones</p>
                </div>

                <button class="btn-comprar">Comprar</button>
            </div>

            <!-- PRODUCTO 4 -->
            <div class="producto">
                <img src="img/monitor.jpeg">
                <h3>Monitor</h3>
                <p>$800,000</p>

                <div class="especificaciones">
                    <p>24 pulgadas</p>
                    <p>144Hz</p>
                    <p>Full HD</p>
                </div>

                <button class="btn-comprar">Comprar</button>
            </div>

        </div>

    </section>

    <!-- FOOTER -->
    <footer id="footer">

        <div class="footer-container">

            <!-- FORM -->
            <div>
                <h3>Contacto</h3>
                <form>
                    <input type="text" placeholder="Nombre" required>
                    <input type="email" placeholder="Correo" required>
                    <button>Enviar</button>
                </form>
            </div>

            <!-- INFO -->
            <div>
                <h3>Datos</h3>
                <p>📍 Barranquilla, Colombia</p>
                <p>📞 300 000 0000</p>
                <p>✉ Tech@gmail.com</p>
            </div>

            <!-- MAP -->
            <div>
                <h3>Ubicación</h3>
                <iframe 
                    src="https://www.google.com/maps?q=Barranquilla&output=embed"
                    width="100%" height="150">
                </iframe>
            </div>

        </div>

    </footer>

</body>
</html>
